  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-zinc-500">
    <div>
      © {year} Naoshi Sato. All rights reserved.
    </div>
    <div class="flex items-center gap-6">
      <a href="#about" class="hover:text-zinc-900 dark:hover:text-white transition">About</a>
      <a href="#services" class="hover:text-zinc-900 dark:hover:text-white transition">Services</a>
      <a href="#contact" class="hover:text-zinc-900 dark:hover:text-white transition">Contact</a>
    </div>
  </div>
</footer>
