---
const skillGroups = [
  {
    title: "Frontend",
    icon: "M4 4h16v4H4zm0 6h10v10H4zm12 0h4v10h-4z",
    items: ["React", "Next.js", "TypeScript", "Astro", "Tailwind CSS", "Vue.js"],
  },
  {
    title: "Backend",
    icon: "M5 12h14M5 6h14M5 18h14",
    items: ["Node.js", "Python", "Go", "Ruby on Rails", "GraphQL", "REST API"],
  },
  {
    title: "Cloud / Infra",
    icon: "M6 19a4 4 0 010-8 6 6 0 0111-3 5 5 0 014 8 4 4 0 01-3 3H6z",
    items: ["AWS", "Cloudflare", "GCP", "Docker", "Kubernetes", "Terraform"],
  },
  {
    title: "Database",
    icon: "M4 7c0-1.7 3.6-3 8-3s8 1.3 8 3-3.6 3-8 3-8-1.3-8-3zm0 5c0 1.7 3.6 3 8 3s8-1.3 8-3M4 7v10c0 1.7 3.6 3 8 3s8-1.3 8-3V7",
    items: ["PostgreSQL", "MySQL", "MongoDB", "Redis", "DynamoDB", "Supabase"],
  },
];
---

<section id="skills" class="relative py-24 md:py-32 border-t border-zinc-200/60 dark:border-zinc-800/60 bg-zinc-50 dark:bg-zinc-950/50 overflow-hidden">
  <!-- decorative blobs -->
  <div aria-hidden="true" class="absolute top-10 -left-32 w-[26rem] h-[26rem] bg-sky-400/30 dark:bg-sky-500/15 rounded-full blur-3xl -z-10 animate-blob"></div>
  <div aria-hidden="true" class="absolute bottom-10 -right-32 w-[24rem] h-[24rem] bg-cyan-400/25 dark:bg-cyan-500/15 rounded-full blur-3xl -z-10 animate-blob-delayed"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3">
        <div class="w-8 h-px bg-blue-600"></div>
        <span class="text-sm font-medium text-blue-600">Skills</span>
      </div>
      <h2 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight">
        技術スタック
      </h2>
      <p class="mt-4 text-zinc-600 dark:text-zinc-400">
        モダンで成熟した技術を中心に、用途とコストに応じた最適な選定を行います。
      </p>
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {skillGroups.map((group) => (
        <div class="p-6 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:border-blue-300 dark:hover:border-blue-800 transition-colors">
          <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-950 flex items-center justify-center text-blue-600">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={group.icon} />
            </svg>
          </div>
          <h3 class="mt-4 font-semibold text-lg">{group.title}</h3>
          <ul class="mt-3 flex flex-wrap gap-1.5">
            {group.items.map((item) => (
              <li class="text-xs px-2.5 py-1 rounded-md bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
