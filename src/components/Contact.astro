---
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string | undefined;
---

<section id="contact" class="py-24 md:py-32 border-t border-zinc-200/60 dark:border-zinc-800/60">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto">
      <span class="text-sm font-medium text-indigo-600">Contact</span>
      <h2 class="mt-2 text-3xl md:text-5xl font-bold tracking-tight">
        お問い合わせ
      </h2>
      <p class="mt-4 text-zinc-600 dark:text-zinc-400">
        お仕事のご相談、ご質問、お見積もり依頼など、下記フォームよりお気軽にお問い合わせください。<br />
        通常 <strong class="text-zinc-900 dark:text-white">1〜2営業日以内</strong> にご返信いたします。
      </p>
    </div>

    <form id="contact-form" class="mt-12 space-y-5">
      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-sm font-medium mb-2">お名前 <span class="text-red-500">*</span></label>
          <input
            id="name"
            name="name"
            type="text"
            required
            placeholder="山田 太郎"
            class="w-full px-4 py-3 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-700 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 outline-none transition"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium mb-2">メールアドレス <span class="text-red-500">*</span></label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@example.com"
            class="w-full px-4 py-3 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-700 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 outline-none transition"
          />
        </div>
      </div>

      <div>
        <label for="company" class="block text-sm font-medium mb-2">会社名 / 屋号</label>
        <input
          id="company"
          name="company"
          type="text"
          placeholder="株式会社サンプル"
          class="w-full px-4 py-3 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-700 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 outline-none transition"
        />
      </div>

      <div>
        <label for="subject" class="block text-sm font-medium mb-2">ご相談内容 <span class="text-red-500">*</span></label>
        <select
          id="subject"
          name="subject"
          required
          class="w-full px-4 py-3 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-700 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 outline-none transition"
        >
          <option value="">選択してください</option>
          <option value="web">Web開発のご依頼</option>
          <option value="system">業務システム開発のご依頼</option>
          <option value="consulting">技術コンサルティングのご相談</option>
          <option value="other">その他のお問い合わせ</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium mb-2">メッセージ <span class="text-red-500">*</span></label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          placeholder="ご相談内容、ご予算、希望納期などをご記入ください。"
          class="w-full px-4 py-3 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-700 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 outline-none transition resize-y"
        ></textarea>
      </div>

      <!-- honeypot -->
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

      {turnstileSiteKey && (
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
      )}

      <div class="flex items-center justify-between gap-4 flex-wrap">
        <p class="text-xs text-zinc-500">送信いただいた情報は、ご返信目的以外には使用しません。</p>
        <button
          type="submit"
          id="submit-btn"
          class="inline-flex items-center gap-2 px-8 py-3 rounded-full bg-zinc-900 text-white dark:bg-white dark:text-zinc-900 font-medium hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span class="btn-label">送信する</span>
          <svg class="btn-icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          <svg class="btn-spinner hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="12" cy="12" r="9" stroke-opacity="0.25" />
            <path d="M21 12a9 9 0 00-9-9" />
          </svg>
        </button>
      </div>

      <div id="form-status" class="hidden text-sm rounded-xl p-4"></div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status") as HTMLDivElement | null;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;

  function showStatus(kind: "success" | "error", msg: string) {
    if (!status) return;
    status.className =
      "text-sm rounded-xl p-4 " +
      (kind === "success"
        ? "bg-emerald-50 dark:bg-emerald-950/40 text-emerald-700 dark:text-emerald-300 border border-emerald-200 dark:border-emerald-900"
        : "bg-red-50 dark:bg-red-950/40 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-900");
    status.textContent = msg;
  }

  function setLoading(loading: boolean) {
    if (!btn) return;
    btn.disabled = loading;
    const label = btn.querySelector(".btn-label") as HTMLElement | null;
    const icon = btn.querySelector(".btn-icon") as HTMLElement | null;
    const spinner = btn.querySelector(".btn-spinner") as HTMLElement | null;
    if (label) label.textContent = loading ? "送信中..." : "送信する";
    icon?.classList.toggle("hidden", loading);
    spinner?.classList.toggle("hidden", !loading);
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !status) return;

    setLoading(true);
    status.classList.add("hidden");

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        throw new Error(j.error || "送信に失敗しました");
      }

      showStatus("success", "お問い合わせありがとうございます。1〜2営業日以内にご返信いたします。");
      form.reset();
    } catch (err) {
      const message = err instanceof Error ? err.message : "送信に失敗しました";
      showStatus("error", `送信に失敗しました: ${message}。お手数ですが時間をおいて再度お試しください。`);
    } finally {
      setLoading(false);
      status.classList.remove("hidden");
    }
  });
</script>
