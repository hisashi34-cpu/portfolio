---
---

<section id="top" class="relative pt-32 pb-24 md:pt-44 md:pb-32 overflow-hidden">
  <!-- subtle background grid -->
  <div class="absolute inset-0 -z-10 [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]">
    <div class="h-full w-full bg-[linear-gradient(to_right,#e4e4e7_1px,transparent_1px),linear-gradient(to_bottom,#e4e4e7_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#27272a_1px,transparent_1px),linear-gradient(to_bottom,#27272a_1px,transparent_1px)] bg-[size:48px_48px]"></div>
  </div>

  <!-- soft gradient blobs -->
  <div aria-hidden="true" class="absolute -top-24 -left-24 w-[28rem] h-[28rem] bg-blue-400/20 dark:bg-blue-500/10 rounded-full blur-3xl -z-10"></div>
  <div aria-hidden="true" class="absolute top-32 -right-24 w-[26rem] h-[26rem] bg-sky-400/20 dark:bg-sky-500/10 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up">
      <span class="inline-flex items-center gap-2 text-xs font-medium px-3 py-1 rounded-full border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        新規案件のご依頼を受付中
      </span>

      <h1 class="mt-6 text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1]">
        テクノロジーで<br class="hidden sm:block" />
        <span class="bg-gradient-to-r from-blue-600 via-sky-500 to-cyan-400 bg-clip-text text-transparent">
          ビジネスの課題
        </span>を解く。
      </h1>

      <p class="mt-6 text-lg md:text-xl text-zinc-600 dark:text-zinc-400 max-w-2xl leading-relaxed">
        Webアプリ開発から業務システム、クラウドインフラ、技術コンサルティングまで。<br class="hidden md:block" />
        中小企業・スタートアップ・個人事業主の方の "困った" をIT で解決します。
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-zinc-900 text-white dark:bg-white dark:text-zinc-900 font-medium hover:opacity-90 transition-opacity"
        >
          お仕事のご依頼
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a
          href="#portfolio"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-zinc-300 dark:border-zinc-700 hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors font-medium"
        >
          実績を見る
        </a>
      </div>

      <div class="mt-16 flex items-center gap-8 text-sm text-zinc-500 dark:text-zinc-400">
        <div>
          <div class="text-2xl font-bold text-zinc-900 dark:text-white">10<span class="text-blue-600">+</span></div>
          <div class="mt-1">年の経験</div>
        </div>
        <div class="w-px h-10 bg-zinc-200 dark:bg-zinc-800"></div>
        <div>
          <div class="text-2xl font-bold text-zinc-900 dark:text-white">50<span class="text-blue-600">+</span></div>
          <div class="mt-1">プロジェクト</div>
        </div>
        <div class="w-px h-10 bg-zinc-200 dark:bg-zinc-800"></div>
        <div>
          <div class="text-2xl font-bold text-zinc-900 dark:text-white">100<span class="text-blue-600">%</span></div>
          <div class="mt-1">満足度</div>
        </div>
      </div>
    </div>
  </div>
</section>
