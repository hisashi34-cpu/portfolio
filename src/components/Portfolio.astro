---
const projects = [
  {
    title: "ECサイトリニューアル",
    category: "Web開発",
    desc: "アパレルブランド様のECサイトをHeadless化。ページ表示速度を3倍に改善し、CVRが23%向上しました。",
    tags: ["Next.js", "Shopify", "Vercel"],
    gradient: "from-rose-200 to-orange-200 dark:from-rose-900 dark:to-orange-900",
  },
  {
    title: "業務日報SaaS",
    category: "プロダクト開発",
    desc: "中小企業向けの業務日報・勤怠管理SaaS。月額課金モデルで100社以上にご導入いただいています。",
    tags: ["TypeScript", "Supabase", "Stripe"],
    gradient: "from-indigo-200 to-violet-200 dark:from-indigo-900 dark:to-violet-900",
  },
  {
    title: "社内DX推進プロジェクト",
    category: "コンサルティング",
    desc: "製造業様の基幹システム刷新を技術顧問として支援。レガシー脱却とクラウド移行を約12ヶ月で完了。",
    tags: ["AWS", "技術顧問", "Architecture"],
    gradient: "from-emerald-200 to-teal-200 dark:from-emerald-900 dark:to-teal-900",
  },
  {
    title: "予約管理システム",
    category: "業務システム",
    desc: "複数店舗を運営する飲食店様向けの統合予約システム。予約処理時間を80%削減しました。",
    tags: ["Vue.js", "Go", "PostgreSQL"],
    gradient: "from-amber-200 to-yellow-200 dark:from-amber-900 dark:to-yellow-900",
  },
  {
    title: "コーポレートサイト",
    category: "Web開発",
    desc: "上場企業様のコーポレートサイトを多言語対応でフルリニューアル。Lighthouseスコア98を達成。",
    tags: ["Astro", "Cloudflare", "i18n"],
    gradient: "from-sky-200 to-cyan-200 dark:from-sky-900 dark:to-cyan-900",
  },
  {
    title: "AIチャットボット",
    category: "AI開発",
    desc: "カスタマーサポート向けのAIチャットボットを構築。問合せ対応工数を月あたり120時間削減。",
    tags: ["Python", "OpenAI", "RAG"],
    gradient: "from-fuchsia-200 to-pink-200 dark:from-fuchsia-900 dark:to-pink-900",
  },
];
---

<section id="portfolio" class="py-24 md:py-32 border-t border-zinc-200/60 dark:border-zinc-800/60 bg-zinc-50 dark:bg-zinc-950/50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-end justify-between flex-wrap gap-4">
      <div class="max-w-2xl">
        <span class="text-sm font-medium text-indigo-600">Portfolio</span>
        <h2 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight">
          実績紹介
        </h2>
        <p class="mt-4 text-zinc-600 dark:text-zinc-400">
          これまでお手伝いさせていただいたプロジェクトの一部をご紹介します。
        </p>
      </div>
    </div>

    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((p) => (
        <article class="group rounded-2xl overflow-hidden bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:shadow-lg hover:-translate-y-0.5 transition-all">
          <div class={`aspect-[16/10] bg-gradient-to-br ${p.gradient} flex items-center justify-center`}>
            <span class="text-zinc-500 dark:text-zinc-400 text-xs font-medium">[ サムネイル ]</span>
          </div>
          <div class="p-6">
            <span class="text-xs font-medium text-indigo-600">{p.category}</span>
            <h3 class="mt-2 font-bold text-lg group-hover:text-indigo-600 transition-colors">{p.title}</h3>
            <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">{p.desc}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {p.tags.map((t) => (
                <span class="text-xs px-2 py-0.5 rounded-md bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
