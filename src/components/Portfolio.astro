---
const projects = [
  {
    title: "社用車走行日報",
    category: "業務SaaS",
    desc: "社用車を使う企業向けの走行・日報管理アプリ。GPS自動記録で日報作成時間を80%削減。",
    tags: ["業務SaaS", "GPS連携", "モバイル対応"],
    gradient: "from-blue-200 to-sky-200 dark:from-blue-900 dark:to-sky-900",
    video: "/projects/vehicle-log-demo.mp4",
  },
  {
    title: "業務日報アプリ",
    category: "業務SaaS",
    desc: "営業職向けの業務日報作成アプリ。提出・確認・集計までを一元化し、報告業務の負荷を軽減。",
    tags: ["業務SaaS", "営業支援", "レポート"],
    gradient: "from-cyan-200 to-blue-200 dark:from-cyan-900 dark:to-blue-900",
    video: "/projects/business-log-demo.mp4",
  },
  {
    title: "出勤管理システム",
    category: "業務システム",
    desc: "従業員の打刻から勤怠集計、PDF出力までを一元管理する勤怠システム。中小企業向けに最適化。",
    tags: ["React", "Firebase", "Vite"],
    gradient: "from-emerald-200 to-teal-200 dark:from-emerald-900 dark:to-teal-900",
  },
  {
    title: "名刺管理サービス tsunagaru",
    category: "Webアプリ",
    desc: "名刺をデジタル化して、ビジネスのつながりを残す名刺管理アプリ。撮影 → 自動データ化 → 検索まで対応。",
    tags: ["Next.js", "Supabase", "Cloudflare"],
    gradient: "from-amber-200 to-yellow-200 dark:from-amber-900 dark:to-yellow-900",
  },
];
---

<section id="portfolio" class="relative py-24 md:py-32 border-t border-zinc-200/60 dark:border-zinc-800/60 bg-zinc-50 dark:bg-zinc-950/50 overflow-hidden">
  <!-- decorative blobs -->
  <div aria-hidden="true" class="absolute top-32 -right-32 w-[30rem] h-[30rem] bg-blue-400/25 dark:bg-blue-500/15 rounded-full blur-3xl -z-10 animate-blob"></div>
  <div aria-hidden="true" class="absolute -bottom-20 -left-32 w-[26rem] h-[26rem] bg-cyan-400/25 dark:bg-cyan-500/15 rounded-full blur-3xl -z-10 animate-blob-delayed"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-end justify-between flex-wrap gap-4">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3">
          <div class="w-8 h-px bg-blue-600"></div>
          <span class="text-sm font-medium text-blue-600">Portfolio</span>
        </div>
        <h2 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight">
          実績紹介
        </h2>
        <p class="mt-4 text-zinc-600 dark:text-zinc-400">
          これまでお手伝いさせていただいたプロジェクトの一部をご紹介します。
        </p>
      </div>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-6">
      {projects.map((p) => (
        <article class="group rounded-2xl overflow-hidden bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:shadow-lg hover:-translate-y-0.5 transition-all">
          <div class={`relative aspect-[16/10] bg-gradient-to-br ${p.gradient} flex items-center justify-center overflow-hidden`}>
            {p.video ? (
              <video
                src={p.video}
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                class="h-[88%] w-auto rounded-2xl ring-4 ring-white/50 dark:ring-zinc-900/40 shadow-2xl"
              ></video>
            ) : (
              <span class="text-zinc-500 dark:text-zinc-400 text-xs font-medium">[ サムネイル ]</span>
            )}
          </div>
          <div class="p-6">
            <span class="text-xs font-medium text-blue-600">{p.category}</span>
            <h3 class="mt-2 font-bold text-lg group-hover:text-blue-600 transition-colors">{p.title}</h3>
            <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">{p.desc}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {p.tags.map((t) => (
                <span class="text-xs px-2 py-0.5 rounded-md bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
